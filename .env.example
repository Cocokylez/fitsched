# Copy this file to .env.local for local development.
# Never commit real secrets. Rotate any value that was ever shared, logged, or committed.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Auth.js / NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google login
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Calendar sync
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""

# Gemini workout-plan generation
GOOGLE_API_KEY=""

# Web push notifications
VAPID_SUBJECT="mailto:security@example.com"
VAPID_PUBLIC_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Encrypt stored OAuth tokens. Must be 32 bytes as base64 or 64 hex characters.
FIELD_ENCRYPTION_KEY=""

# App behavior
FITSCHED_TIME_ZONE="Asia/Singapore"
